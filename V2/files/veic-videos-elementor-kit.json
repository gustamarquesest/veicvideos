  "page_settings": [],
  "site_settings": {
    "custom_css": "/* Veic Vídeos — Custom CSS Global */\n\nbody {\n  background-color: #131210;\n  color: #FEFBF3;\n}\n\n/* Scrollbar personalizada */\n::-webkit-scrollbar { width: 6px; }\n::-webkit-scrollbar-track { background: #131210; }\n::-webkit-scrollbar-thumb { background: #FFB600; border-radius: 3px; }\n::-webkit-scrollbar-thumb:hover { background: #CC9200; }\n\n/* Seleção de texto */\n::selection { background: #FFB600; color: #131210; }\n\n/* Links globais */\na { color: #FFB600; transition: color 0.2s; }\na:hover { color: #CC9200; }\n\n/* Classe utilitária para texto amarelo */\n.text-yellow { color: #FFB600 !important; }\n.text-creme { color: #FEFBF3 !important; }\n.bg-preto { background-color: #131210 !important; }\n.bg-cinza { background-color: #1e1c1a !important; }\n\n/* Botão secundário (outline) */\n.btn-outline {\n  background: transparent !important;\n  border: 1px solid rgba(254,251,243,0.2) !important;\n  color: #FEFBF3 !important;\n  transition: border-color 0.2s, color 0.2s !important;\n}\n.btn-outline:hover {\n  border-color: #FFB600 !important;\n  color: #FFB600 !important;\n}\n\n/* Badge / tag da marca */\n.veic-badge {\n  display: inline-flex;\n  align-items: center;\n  gap: 8px;\n  background: rgba(255,182,0,0.12);\n  border: 1px solid rgba(255,182,0,0.3);\n  color: #FFB600;\n  font-size: 0.75rem;\n  font-weight: 700;\n  letter-spacing: 0.08em;\n  text-transform: uppercase;\n  padding: 0.4rem 1rem;\n  border-radius: 100px;\n}\n\n/* Divisor amarelo */\n.veic-divider {\n  width: 48px;\n  height: 3px;\n  background: #FFB600;\n  margin: 1rem 0;\n}"
  }
